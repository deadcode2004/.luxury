APP_NAME="Paradise Luxury"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

# Comma-separated extra browser origins allowed by CORS (Vercel + local)
FRONTEND_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Example production:
# FRONTEND_URL=https://luxury-khaki-eight.vercel.app
# CORS_ALLOWED_ORIGINS=https://luxury-khaki-eight.vercel.app
# Regex patterns (fruitcake/cors), e.g. all Vercel previews:
# CORS_ALLOWED_ORIGIN_PATTERNS=#^https://.*\\.vercel\\.app$#
CORS_ALLOWED_ORIGIN_PATTERNS=

APP_LOCALE=ar
APP_FALLBACK_LOCALE=en

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=paradise_luxury
DB_USERNAME=paradise
DB_PASSWORD=paradise

# Prefer redis in production. For a minimal local setup without Redis, use:
# SESSION_DRIVER=file
# QUEUE_CONNECTION=sync
# CACHE_STORE=file
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis
CACHE_STORE=redis
FILESYSTEM_DISK=public

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Include every frontend host that may call the API with cookies/credentials.
SANCTUM_STATEFUL_DOMAINS=localhost:3000,127.0.0.1:3000
# Production example:
# SANCTUM_STATEFUL_DOMAINS=luxury-khaki-eight.vercel.app,localhost:3000,127.0.0.1:3000
