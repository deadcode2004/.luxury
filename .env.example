# Frontend environment (Local + Vercel)
# Copy to `.env.local` for local development.

# Same-origin API prefix used by the browser (recommended).
# Next.js rewrites this to Laravel via API_PROXY_ORIGIN.
NEXT_PUBLIC_API_URL=/api/v1

# Laravel origin used by Next.js rewrites (server-side only — not exposed to the browser).
# Local:
API_PROXY_ORIGIN=http://127.0.0.1:8000
# Production example:
# API_PROXY_ORIGIN=https://api.your-domain.com

# Optional absolute override (bypasses Next rewrite; requires CORS on Laravel):
# NEXT_PUBLIC_API_URL=https://api.your-domain.com/api/v1
